# environments/prod.tfvars.example
#
# This is a template, not a real config — it is safe to commit since it
# contains no secrets, only placeholders. Copy it to a real, gitignored
# environments/prod.tfvars before filling in your own values:
#
#   cp environments/prod.tfvars.example environments/prod.tfvars
#   # edit environments/prod.tfvars with your real key_name / IP
#   terraform apply -var-file=environments/prod.tfvars
#
# environments/prod.tfvars is covered by the *.tfvars rule in .gitignore,
# so it will never be committed by accident.

aws_region    = "us-east-1"
environment   = "prod"
project_name  = "docker-swarm"
instance_type = "t3.small"
worker_count  = 3
key_name      = "REPLACE_WITH_YOUR_AWS_KEY_PAIR_NAME"

# No public default for security reasons — set this to your own IP or a
# corporate VPN/bastion CIDR, never 0.0.0.0/0.
ssh_allowed_cidr_blocks = ["REPLACE_WITH_YOUR_IP/32"]

# .gitignore
.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl
*.tfvars
*.pem
.DS_Store

# *.tfvars.example files are intentionally NOT matched by the *.tfvars rule
# above (they end in .example, not .tfvars) — they are safe-to-commit
# templates. Only real *.tfvars files (with actual values) are ignored.
# terraform.tfvars.example
#
# For a plain single-environment deploy that doesn't need the
# environments/ structure. Copy this to terraform.tfvars (gitignored)
# and fill in your own values:
#
#   cp terraform.tfvars.example terraform.tfvars
#   terraform apply

aws_region    = "us-east-1"
environment   = "dev"
project_name  = "docker-swarm"
instance_type = "t3.micro"
worker_count  = 2
key_name      = "REPLACE_WITH_YOUR_AWS_KEY_PAIR_NAME"

# No public default for security reasons — set this to your own IP.
ssh_allowed_cidr_blocks = ["REPLACE_WITH_YOUR_IP/32"]
